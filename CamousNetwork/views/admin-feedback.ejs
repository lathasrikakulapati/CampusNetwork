<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Feedback</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f9f9f9; margin: 0; }
        .navbar { background: #232f3e; padding: 1rem; color: white; }
        .navbar a { color: white; text-decoration: none; margin-right: 1rem; }
        .container { max-width: 1200px; margin: 2rem auto; padding: 0 1rem; }
        .feedback-item { background: white; padding: 1.5rem; border-radius: 8px; margin-bottom: 1rem; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .feedback-item h3 { margin: 0 0 0.5rem 0; }
        table { width: 100%; border-collapse: collapse; background: white; margin-top: 1rem; }
        table th, table td { padding: 0.75rem; border: 1px solid #ddd; text-align: left; }
        table th { background: #f0f0f0; font-weight: bold; }
    </style>
</head>
<body>
    <div class="navbar">
        <h1 style="display:inline; margin:0;">User Feedback</h1>
        <div style="float:right;">
            <a href="/admin">Dashboard</a>
            <a href="/auth/logout">Logout</a>
        </div>
    </div>

    <div class="container">
        <h2>All Feedback</h2>
        <% if (feedbacks.length === 0) { %>
            <div class="feedback-item">
                <p>No feedback received yet.</p>
            </div>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>User Email</th>
                        <th>Rating</th>
                        <th>Feedback</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    <% feedbacks.forEach(f => { %>
                        <tr>
                            <td><%= f.userEmail %></td>
                            <td><%= f.rating %>/5</td>
                            <td><%= f.feedback %></td>
                            <td><%= new Date(f.createdAt).toLocaleDateString() %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </div>
</body>
</html>
