<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Placement Events</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f9f9f9; margin: 0; }
        .navbar { background: #232f3e; padding: 1rem; color: white; }
        .navbar a { color: white; text-decoration: none; margin-right: 1rem; }
        .container { max-width: 1200px; margin: 2rem auto; padding: 0 1rem; }
        .form-section { background: white; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .form-group { margin-bottom: 1rem; }
        label { display: block; font-weight: bold; margin-bottom: 0.3rem; }
        input, textarea, select { width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box; }
        button { padding: 0.75rem 1.5rem; background: #4caf50; color: white; border: none; border-radius: 4px; cursor: pointer; }
        button:hover { background: #45a049; }
        table { width: 100%; border-collapse: collapse; background: white; }
        table th, table td { padding: 0.75rem; border: 1px solid #ddd; text-align: left; }
        table th { background: #f0f0f0; font-weight: bold; }
        .btn-delete { background: #dc3545; padding: 0.5rem 1rem; font-size: 0.9rem; }
        .btn-delete:hover { background: #c82333; }
    </style>
</head>
<body>
    <div class="navbar">
        <h1 style="display:inline; margin:0;">Manage Placement Events</h1>
        <div style="float:right;">
            <a href="/admin">Dashboard</a>
            <a href="/auth/logout">Logout</a>
        </div>
    </div>

    <div class="container">
        <div class="form-section">
            <h2>Add New Event</h2>
            <form id="addEventForm">
                <div class="form-group">
                    <label>Company Name:</label>
                    <input type="text" id="companyName" name="companyName" required>
                </div>
                <div class="form-group">
                    <label>Event Date:</label>
                    <input type="date" id="eventDate" name="eventDate" required>
                </div>
                <div class="form-group">
                    <label>Number of Rounds:</label>
                    <input type="number" id="rounds" name="rounds" value="1" min="1" required>
                </div>
                <div class="form-group">
                    <label>Round Types:</label>
                    <input type="text" id="roundTypes" name="roundTypes" placeholder="e.g., Written, Technical, HR">
                </div>
                <button type="submit">Add Event</button>
            </form>
        </div>

        <div class="form-section">
            <h2>Upload Calendar Image</h2>
            <form id="uploadImageForm" enctype="multipart/form-data">
                <div class="form-group">
                    <label>Select Image:</label>
                    <input type="file" id="calendarImage" name="calendarImage" accept="image/*">
                </div>
                <button type="submit">Upload Image</button>
            </form>
            <div id="uploadResult" style="margin-top:10px;color:green"></div>
        </div>

        <div class="form-section">
            <h2>Placement Events List</h2>
            <table>
                <thead>
                    <tr>
                        <th>Company</th>
                        <th>Date</th>
                        <th>Rounds</th>
                        <th>Round Types</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="eventsTable">
                    <% if (events.length === 0) { %>
                        <tr><td colspan="5" style="text-align:center;">No events yet</td></tr>
                    <% } else { %>
                        <% events.forEach(e => { %>
                            <tr>
                                <td><%= e.companyName %></td>
                                <td><%= new Date(e.eventDate).toLocaleDateString() %></td>
                                <td><%= e.rounds %></td>
                                <td><%= e.roundTypes || 'N/A' %></td>
                                <td>
                                    <button class="btn-delete" onclick="deleteEvent('<%= e._id %>')">Delete</button>
                                </td>
                            </tr>
                        <% }); %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        document.getElementById('addEventForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = {
                companyName: document.getElementById('companyName').value,
                eventDate: document.getElementById('eventDate').value,
                rounds: parseInt(document.getElementById('rounds').value),
                roundTypes: document.getElementById('roundTypes').value
            };

            try {
                const res = await fetch('/api/placement', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });

                if (res.ok) {
                    alert('Event added successfully!');
                    document.getElementById('addEventForm').reset();
                    location.reload();
                } else {
                    const error = await res.json();
                    alert('Error: ' + error.error);
                }
            } catch (err) {
                alert('Error adding event: ' + err.message);
            }
        });

        async function deleteEvent(id) {
            if (!confirm('Are you sure you want to delete this event?')) return;

            try {
                const res = await fetch(`/api/placement/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    alert('Event deleted!');
                    location.reload();
                } else {
                    alert('Error deleting event');
                }
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }
        
        // Upload calendar image
        document.getElementById('uploadImageForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const fileInput = document.getElementById('calendarImage');
            if (!fileInput.files.length) return alert('Please select an image');

            const fd = new FormData();
            fd.append('calendarImage', fileInput.files[0]);

            try {
                const res = await fetch('/admin/placement-image', { method: 'POST', body: fd });
                const json = await res.json();
                if (res.ok) {
                    document.getElementById('uploadResult').textContent = 'Image uploaded successfully';
                } else {
                    alert('Upload error: ' + (json.error || 'unknown'));
                }
            } catch (err) {
                alert('Upload failed: ' + err.message);
            }
        });
    </script>
</body>
</html>
